    {
      "parameters": {
        "jsCode": "// Extrai códigos E busca dados da Planilha Y (tudo junto)\nconst itemsX = $input.all();\nconst dadosPlanilhaY = $('Get row(s) in sheet2').all(); // Node 11\n\nconst codigosParaBuscar = [];\n\nitemsX.forEach((item, index) => {\n  if (index === 0 || index === 1) return;\n  \n  const row = item.json;\n  const codigoPrincipal = (row.Código || '').trim();\n  if (!codigoPrincipal) return;\n  \n  const colunas = {\n    'G': row.NOVO_Alimenta || '',\n    'H': row['DEMOLIÇÃO_alimenta'] || '',\n    'I': row['EXISTENTE MANTIDO_alimenta'] || '',\n    'J': row['REMANEJADO EXTERNO_alimenta'] || '',\n    'K': row['REMANEJADO LOCAL_alimenta'] || ''\n  };\n  \n  Object.keys(colunas).forEach(col => {\n    const conteudo = colunas[col];\n    if (conteudo && conteudo.trim()) {\n      conteudo.split(/[,\\n]+/).forEach((codigo, idx) => {\n        const limpo = codigo.trim();\n        if (limpo && limpo.length > 2 && !(idx === 0 && limpo === codigoPrincipal)) {\n          codigosParaBuscar.push(limpo);\n        }\n      });\n    }\n  });\n});\n\n// Remover duplicatas\nconst codigosUnicos = [...new Set(codigosParaBuscar)];\n\n// BUSCAR na Planilha Y imediatamente\nconst resultado = [];\ncodigosUnicos.forEach(codigo => {\n  const linhaY = dadosPlanilhaY.find(item => \n    String(item.json['Código'] || '').trim() === codigo\n  );\n  \n  if (linhaY) {\n    const row = linhaY.json;\n    resultado.push({ \n      json: {\n        'Categoria': row['Categoria'] || '',\n        'Subcategoria': row['Subcategoria'] || '',\n        'Grupo': row['Grupo'] || '',\n        'Código': codigo,\n        'Status': '',\n        'Descrição': row['Descrição'] || '',\n        'NOVO_Alimenta': row['NOVO_Alimenta'] || '',\n        'DEMOLIÇÃO_alimenta': row['DEMOLIÇÃO_alimenta'] || '',\n        'EXISTENTE MANTIDO_alimenta': row['EXISTENTE MANTIDO_alimenta'] || '',\n        'REMANEJADO EXTERNO_alimenta': row['REMANEJADO EXTERNO_alimenta'] || '',\n        'REMANEJADO LOCAL_alimenta': row['REMANEJADO LOCAL_alimenta'] || '',\n        'Unidade de medida': row['Unidade de medida'] || ''\n      }\n    });\n  }\n});\n\nreturn resultado;"
      },
