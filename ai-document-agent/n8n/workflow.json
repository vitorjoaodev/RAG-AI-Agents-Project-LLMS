    {
      "parameters": {
        "jsCode": "// Agrupar dados do Revit por Keynote (limpando tabs e espaços)\nconst items = $input.all();\nconst agrupado = {};\n\nconsole.log('=== PROCESSANDO PLANILHA REVIT ===');\nconsole.log('Total de linhas:', items.length);\n\nitems.forEach((item, index) => {\n  const row = item.json;\n  \n  // Limpar tabs e espaços dos nomes das colunas\n  const area = row['Area'] || '';\n  const length = row['\tLenght'] || row['Lenght'] || '';\n  const count = row['\tCount'] || row['Count'] || '';\n  const keynote = row['        Keynote'] || row['Keynote'] || '';\n  const status = row['        Status'] || row['Status'] || '';\n  \n  // Limpar tabs e espaços dos VALORES\n  const keynoteLimpo = String(keynote).replace(/[\\t\\s]/g, '').trim();\n  \n  // Pular se não tiver Keynote válido\n  if (!keynoteLimpo || keynoteLimpo.length < 3) {\n    return;\n  }\n  \n  // Inicializar\n  if (!agrupado[keynoteLimpo]) {\n    agrupado[keynoteLimpo] = {\n      keynote: keynoteLimpo,\n      status: '',\n      areas: [],\n      lengths: [],\n      counts: []\n    };\n  }\n  \n  // Adicionar valores\n  const areaNum = parseFloat(String(area).replace(/[\\t\\s]/g, '')) || 0;\n  const lengthNum = parseFloat(String(length).replace(/[\\t\\s]/g, '')) || 0;\n  const countNum = parseFloat(String(count).replace(/[\\t\\s]/g, '')) || 0;\n  \n  if (areaNum > 0) agrupado[keynoteLimpo].areas.push(areaNum);\n  if (lengthNum > 0) agrupado[keynoteLimpo].lengths.push(lengthNum);\n  if (countNum > 0) agrupado[keynoteLimpo].counts.push(countNum);\n  \n  // Status (primeiro não vazio)\n  const statusLimpo = String(status).replace(/[\\t\\s]+/g, ' ').trim();\n  if (statusLimpo && !agrupado[keynoteLimpo].status) {\n    agrupado[keynoteLimpo].status = statusLimpo;\n  }\n});\n\n// Formatar resultado\nconst resultado = Object.values(agrupado).map(grupo => {\n  const areaText = grupo.areas.length > 0\n    ? `(${grupo.areas.length} resultados): ${grupo.areas.join(' + ')} / Soma = ${grupo.areas.reduce((a,b) => a+b, 0).toFixed(2)}`\n    : '';\n  \n  const lengthText = grupo.lengths.length > 0\n    ? `(${grupo.lengths.length} resultados): ${grupo.lengths.join(' + ')} / Soma = ${grupo.lengths.reduce((a,b) => a+b, 0).toFixed(2)}`\n    : '';\n  \n  const countText = grupo.counts.length > 0\n    ? `(${grupo.counts.length} resultados): ${grupo.counts.map(c => Math.round(c)).join(' + ')} / Soma = ${Math.round(grupo.counts.reduce((a,b) => a+b, 0))}`\n    : '';\n  \n  return {\n    json: {\n      Código: grupo.keynote,\n      Status: grupo.status,\n      'AREA m2': areaText,\n      'COMPRIMENTO m': lengthText,\n      'CONTAGEM UNID': countText\n    }\n  };\n});\n\nconsole.log('Total de Keynotes únicos:', resultado.length);\nreturn resultado;"
      },
